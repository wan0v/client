{
  "name": "gryt-chat",
  "private": true,
  "version": "1.1.1",
  "description": "Gryt Chat — real-time voice chat desktop client",
  "author": {
    "name": "Gryt Chat",
    "email": "sivert@gryt.chat",
    "url": "https://gryt.chat"
  },
  "license": "AGPL-3.0-or-later",
  "homepage": "https://gryt.chat",
  "repository": {
    "type": "git",
    "url": "https://github.com/Gryt-chat/gryt"
  },
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "tsc -b && eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "build:native": "node -e \"require('child_process').execSync(process.platform==='win32'?'native\\\\audio-capture\\\\windows\\\\build.bat':'bash native/audio-capture/build.sh',{stdio:'inherit'})\"",
    "electron:dev": "cross-env ELECTRON=1 vite --host",
    "electron:build": "npm run build:native && cross-env ELECTRON=1 vite build && electron-builder --publish never",
    "electron:publish": "npm run build:native && cross-env ELECTRON=1 vite build && electron-builder --publish always",
    "release": "bash scripts/release.sh",
    "electron:preview": "npm run build:native && cross-env ELECTRON=1 vite build && electron ."
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/themes": "^3.3.0",
    "@shiguredo/rnnoise-wasm": "^2025.1.5",
    "axios": "^1.13.5",
    "bonjour-service": "^1.3.0",
    "electron-updater": "^6.8.3",
    "fflate": "^0.8.2",
    "gemoji": "^8.1.0",
    "jwt-decode": "^4.0.0",
    "keycloak-js": "^26.2.3",
    "motion": "^12.34.2",
    "react": "^18.3.1",
    "react-canvas-confetti": "^2.0.7",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "react-rewards": "^2.1.0",
    "react-singleton-hook": "^4.0.1",
    "rehype-highlight": "^7.0.2",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "socket.io-client": "^4.8.3",
    "uiohook-napi": "^1.5.4",
    "use-sound": "^4.0.4",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "cross-env": "^10.1.0",
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "optionalDependencies": {
    "dmg-license": "1.0.11"
  }
}
